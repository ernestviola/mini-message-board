<form action="/new" method="post" class="new-message__form">
  <label for="user"
    >Name:
    <input type="text" id="user" name="username" autocapitalize="on" required
  /></label>
  <label for="message"
    >Message:
    <textarea
      name="message"
      id="message"
      rows="4"
      autocapitalize="on"
      required
    ></textarea>
  </label>
  <button type="submit" class="form-submit">Submit</button>
</form>
